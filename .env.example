# Copy this file to .env and fill in the values from your Supabase project.
# These are exposed to the browser (VITE_ prefix), so use only the publishable
# (anon) key here — never the service_role key.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key
